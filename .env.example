APP_KEY=
APP_URL=

DB_CONNECTION=sqlite

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# Redis (optional - install redis service to use)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=null

# Uncomment to switch to Redis-backed drivers
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis

# RoadRunner
# RR_PORT=80
# RR_NUM_WORKERS=0
# RR_MAX_JOBS=0
# RR_MAX_WORKER_MEMORY=128

# Queue workers
# WORKER_NUMPROCS=2
